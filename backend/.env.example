# Backend environment variables for local development
# Copy this file to .env and update values for your environment

HOST=0.0.0.0
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGO_URI=mongodb://127.0.0.1:27017/m2_shop

# JWT Configuration
JWT_SECRET=your_very_secure_jwt_secret_key_change_this_in_production_12345
JWT_EXPIRES_IN=7d

# CORS Configuration (comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:3000,http://localhost:8080,http://127.0.0.1:5000

# File Upload Configuration
UPLOAD_LIMIT=10mb
UPLOAD_DIR=./uploads
